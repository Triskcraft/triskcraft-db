datasource db {
  provider = "postgresql"
}

/// Configuración del cliente de Prisma orientado a TypeScript con soporte
/// para ESM y rutas generadas bajo `src/prisma/generated`.
generator client {
  provider               = "prisma-client"
  engineType             = "client"
  output                 = "../src/generated"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["typedSql"]
}

/// Periodo de inactividad declarado por un usuario de Discord.
model InactivityPeriod {
  user_id       String   @id
  guild_id      String
  role_snapshot String
  started_at    DateTime @default(now())
  ends_at       DateTime
  source        String
  notified      Boolean  @default(false)

  discord_user DiscordUser @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("inactivity_periods")
}

/// Rol monitoreado dentro de un servidor de Discord.
model TrackedRole {
  guild_id   String
  role_id    String
  created_at DateTime @default(now())

  @@id([guild_id, role_id])
  @@map("tracked_roles")
}

/// Instantáneas de actividad/inactividad por rol para graficar tendencias.
model RoleStatistic {
  id             String   @id @default(dbgenerated("snowflake()"))
  guild_id       String
  role_id        String
  inactive_count Int      @default(0)
  active_count   Int      @default(0)
  captured_at    DateTime @default(now())

  @@map("role_statistics")
}

/// Código temporal utilizado para vincular cuentas externas con Discord.
model LinkCode {
  id               String @id @default(dbgenerated("snowflake()"))
  discord_id       String @unique
  discord_nickname String
  code             String @unique

  discord_user DiscordUser @relation(fields: [discord_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("link_codes")
}

/// Catálogo de roles disponibles para usuarios de Minecraft.
model MinecraftRole {
  id   String @id @default(dbgenerated("snowflake()"))
  name String @unique

  linked_roles LinkedMinecraftRole[]

  @@map("minecraft_roles")
}

/// Relación N:M entre usuarios de Minecraft y los roles asignados.
model LinkedMinecraftRole {
  mc_user_uuid String
  role_id      String

  role   MinecraftRole @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  player Player        @relation(fields: [mc_user_uuid], references: [uuid], onDelete: Cascade, onUpdate: Cascade)

  @@id([mc_user_uuid, role_id])
  @@map("linked_minecraft_roles")
}

/// Medios o enlaces externos asociados a cada jugador de Minecraft.
model Media {
  id           String @id @default(dbgenerated("snowflake()"))
  mc_user_uuid String
  type         String
  url          String

  player Player @relation(fields: [mc_user_uuid], references: [uuid], onDelete: Cascade, onUpdate: Cascade)

  @@unique([mc_user_uuid, type])
  @@map("medias")
}

enum PLAYER_STATUS {
  ACTIVE
  DELETED
}

/// Información de jugador de Minecraft enlazada con su usuario de Discord.
model Player {
  /// El uuid del jugador en formato UUID
  uuid        String        @id
  nickname    String        @unique
  digs        Int           @default(0)
  description String        @default("")
  status      PLAYER_STATUS @default(ACTIVE)
  /// La ultima vez que entró
  last_seen   DateTime?

  linked_roles LinkedMinecraftRole[]
  medias       Media[]
  user         User?

  @@map("minecraft_players")
}

/// Representa a un usuario de Discord, incluyendo su rango y relaciones.
model DiscordUser {
  id       String @id
  username String @unique

  inactivity_periods InactivityPeriod[]
  link_code          LinkCode?
  post_blocks        PostBlocks[]
  user               User?

  @@map("discord_users")
}

model WebhookToken {
  id          String   @id @default(dbgenerated("snowflake()"))
  name        String   @unique
  user_id     String
  secret      String
  permissions String[]
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("webhook_tokens")
}

model State {
  id         String   @id @default(dbgenerated("snowflake()"))
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("states")
}

enum POST_STATUS {
  DRAFT
  PUBLISHED
  OUTDATED
}

model Post {
  id             String      @id @default(dbgenerated("snowflake()"))
  title          String      @unique
  user_id        String
  thread_id      String
  status         POST_STATUS @default(DRAFT)
  cover_media_id String?     @unique
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  post_blocks PostBlocks[]
  cover_media PostMedia?   @relation("PostCoverMedia", fields: [cover_media_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("posts")
}

model PostBlocks {
  message_id String   @id
  post_id    String
  timestamp  DateTime
  content    String?
  components Json[]   @default([])
  embeds     Json[]   @default([])
  author_id  String

  author DiscordUser      @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  post   Post             @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  media  PostBlockMedia[]

  @@map("post_blocks")
}

enum POST_BLOCK_MEDIA_TYPE {
  IMAGE
  VIDEO
  AUDIO
  FILE
}

model PostMedia {
  id           String                @id @default(dbgenerated("snowflake()"))
  filename     String
  url          String
  content_type String?
  media_type   POST_BLOCK_MEDIA_TYPE
  size         Int
  width        Int?
  height       Int?
  description  String?
  hash         String?

  post_blocks    PostBlockMedia[]
  cover_for_post Post?            @relation("PostCoverMedia")

  @@index([hash])
  @@index([media_type])
  @@map("post_media")
}

model PostBlockMedia {
  post_block_message_id String
  media_id              String
  position              Int    @default(0)

  post_block PostBlocks @relation(fields: [post_block_message_id], references: [message_id], onDelete: Cascade, onUpdate: Cascade)
  media      PostMedia  @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([post_block_message_id, media_id, position])
  @@index([media_id])
  @@map("post_block_media")
}

model User {
  id              String   @id @default(dbgenerated("snowflake()"))
  mc_player_uuid  String?  @unique
  discord_user_id String   @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  mc_player    Player?     @relation(fields: [mc_player_uuid], references: [uuid], onDelete: SetNull, onUpdate: Cascade)
  discord_user DiscordUser @relation(fields: [discord_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  authorization_codes AuthorizationCode[]
  sessions            Session[]
  linked_roles        LinkedRole[]
  posts               Post[]
  webhook_tokens      WebhookToken[]

  @@map("users")
}

model Client {
  id            String   @id
  client_secret String?
  redirect_uris String[]
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  scopes        String[]

  authorization_codes AuthorizationCode[]
  sessions            Session[]

  @@map("clients")
}

model AuthorizationCode {
  id             String   @id @default(dbgenerated("snowflake()"))
  code           String   @unique
  user_id        String
  client_id      String
  redirect_uri   String
  code_challenge String
  expires_at     DateTime
  created_at     DateTime @default(now())
  scope          String

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("authorization_codes")
}

model Session {
  id            String   @id @default(dbgenerated("snowflake()"))
  user_id       String
  /// Hashed
  refresh_token String   @unique
  client_id     String
  scope         String   @default("")
  expires_at    DateTime
  created_at    DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("sessions")
}

model Role {
  id          String @id @default(dbgenerated("snowflake()"))
  name        String @unique
  /// permisos como Bit Flags
  permissions BigInt @default(0)

  linked_roles LinkedRole[]

  @@map("roles")
}

model LinkedRole {
  user_id String
  role_id String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([user_id, role_id])
  @@map("linked_roles")
}
